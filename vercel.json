{
  "redirects": [
    {
      "source": "/app/:path*/ferramentas/lsp",
      "destination": "/lsp.html",
      "permanent": false
    },
    {
      "source": "/app/:path*/ferramentas/sql",
      "destination": "/sql.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/lsp.html",
      "destination": "/lsp.html"
    },
    {
      "source": "/sql.html",
      "destination": "/sql.html"
    }
  ]
}
