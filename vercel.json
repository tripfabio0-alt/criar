{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/gerador",
      "destination": "/gerador/index.html"
    },
    {
      "source": "/gerador/sql",
      "destination": "/gerador/sql.html"
    },
    {
      "source": "/gerador/(.*)",
      "destination": "/gerador/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
